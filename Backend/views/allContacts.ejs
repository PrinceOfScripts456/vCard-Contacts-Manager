<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contacts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="../style/allContacts.css">
</head>

<body data-bs-theme="dark">

    <!-- Nav Bar -->
    <%- include('partials/header') %>


        <!-- Contacts Box -->
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mx-4 my-3 contacts-box">

            <div class="col">
                <div class="card">
                    <img src="" class="card-img-top" alt="..."
                        style="height:200px; object-fit:cover; background-color:#868e96;">
                    <div class="card-body">
                        <h5 class="card-title">Full Name</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of
                            the
                            card’s content.</p>
                    </div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><b> Phone Number(s):</b> 0346-9023424</li>
                        <li class="list-group-item"><b>Email:</b> prince@gmail.com</li>
                        <li class="list-group-item"><b>Date:</b> 21/05/2026</li>
                        <li class="list-group-item"><b>Note:</b> Life is very strange Stranger!</li>
                    </ul>
                    <div class="card-footer">
                        <small class="text-body-secondary">Last updated 3 mins ago</small>
                    </div>
                </div>
                <div class="m-2">
                    <a class="btn btn-primary m-1">Edit</a>
                    <a href="#" class="btn btn-danger m-1">Delete</a>
                </div>
            </div>

            <% contacts.forEach( (contact)=> { %>
                <div class="col">
                    <div class="card">
                        <img src="" class="card-img-top" alt="..."
                            style="height:200px; object-fit:cover; background-color:#868e96;">
                        <div class="card-body">
                            <h5 class="card-title">
                                <%= contact.name %>
                            </h5>
                            <p class="card-text">Some quick example text to build on the card title and make up the bulk
                                of
                                the card’s content.</p>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item"><b>Phone Number(s):</b>
                                <%= contact.telephone %>
                            </li>
                            <li class="list-group-item"><b>Email:</b>
                                <%= contact.email %>
                            </li>
                            <li class="list-group-item"><b>Date:</b>
                                <%= contact.date %>
                            </li>
                            <li class="list-group-item"><b>Note:</b>
                                <%= contact.note %>
                            </li>
                        </ul>
                        <div class="card-footer">
                            <small class="text-body-secondary">
                                <%= contact.created_on %>
                            </small>
                        </div>
                    </div>
                    <div class="m-2">
                        <a class="btn btn-primary m-1">Edit</a>
                        <a href="#" class="btn btn-danger m-1">Delete</a>
                    </div>
                </div>
                <% }); %>

                    <div class="col">
                        <div class="card">
                            <img src="" class="card-img-top" alt="..."
                                style="height:200px; object-fit:cover; background-color:#868e96;">
                            <div class="card-body">
                                <h5 class="card-title">Card title</h5>
                                <p class="card-text">Some quick example text to build on the card title and make up the
                                    bulk
                                    of the
                                    card’s content.</p>
                            </div>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">An item</li>
                                <li class="list-group-item">A second item</li>
                                <li class="list-group-item">A third item</li>
                            </ul>
                            <div class="card-footer">
                                <small class="text-body-secondary">Last updated 46 mins ago</small>
                            </div>
                        </div>
                        <div class="m-2">
                            <a href="#" class="btn btn-primary m-1">Card link</a>
                            <a href="#" class="card-link m-1">Another link</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="card" aria-hidden="true">
                            <img src="" class="card-img-top" alt="..."
                                style="height:200px; object-fit:cover; background-color:#868e96;">
                            <div class="card-body">
                                <h5 class="card-title placeholder-glow">
                                    <span class="placeholder col-6"></span>
                                </h5>
                                <p class="card-text placeholder-glow">
                                    <span class="placeholder col-7"></span>
                                    <span class="placeholder col-4"></span>
                                    <span class="placeholder col-4"></span>
                                    <span class="placeholder col-6"></span>
                                    <span class="placeholder col-8"></span>
                                </p>
                                <a class="btn btn-primary disabled placeholder col-6" aria-disabled="true"></a>
                            </div>
                        </div>
                    </div>

        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
        <script src="../script/allContacts.js"></script>
</body>

</html>