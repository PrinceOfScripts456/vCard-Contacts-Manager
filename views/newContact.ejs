<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create new Contact</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>

    <!-- Nav Bar -->
    <%- include('partials/header') %>

        <!-- Container -->
        <div class="card m-2 p-2">

            <!-- Profile Picture -->
            <div class="row">
                <div class="col">
                    <img src="/images/default.svg" class="d-block rounded-circle mb-3" width="120px" alt="...">
                </div>
            </div>

            <!-- Data Form -->
            <form method="post" action="/contacts/new" id="newContactForm" class="row row-cols-1 g-3 needs-validation"
                novalidate>

                <!-- First Name -->
                <div class="col-md-4">
                    <label for="validationFirstName" class="form-label">First name</label>
                    <input type="text" class="form-control" id="validationFirstName" name="firstName" value="Your"
                        required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please choose a first name.
                    </div>
                </div>

                <!-- Last Name -->
                <div class="col-md-4">
                    <label for="validationLastName" class="form-label">Last name</label>
                    <input type="text" class="form-control" id="validationLastName" name="lastName" value="Name?"
                        required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please choose a last name.
                    </div>
                </div>

                <!-- Phone Number -->
                <div class="col-md-4">
                    <label for="validationPhoneNumber" class="form-label">Phone Number</label>
                    <input type="number" class="form-control" id="validationPhoneNumber" name="telephone"
                        value="03420290152" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please enter a phone number.
                    </div>
                </div>

                <!-- Email -->
                <div class="col-md-4">
                    <label for="validationEmail" class="form-label">Email</label>
                    <div class="input-group has-validation">
                        <span class="input-group-text" id="inputGroupPrepend">@</span>
                        <input type="email" class="form-control" id="validationEmail" name="email"
                            value="google123@gmail.com" aria-describedby="inputGroupPrepend">
                        <div class="invalid-feedback">
                            Please choose a valid email.
                        </div>
                    </div>
                </div>

                <!-- Date -->
                <div class="col-md-6">
                    <label for="validationDate" class="form-label">Date</label>
                    <input type="date" class="form-control" id="validationDate" name="date">
                    <div class="invalid-feedback">
                        Please provide a date.
                    </div>
                </div>

                <!-- Note -->
                <div class="col-md-4">
                    <label for="validationNote" class="form-label">Note</label>
                    <textarea class="form-control" id="validationNote" name="note" rows="3"></textarea>
                    <div class="invalid-feedback">
                        Please provide a valid Note.
                    </div>
                </div>

                <!-- Terms and Conditions -->
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="" id="invalidCheck" required>
                        <label class="form-check-label" for="invalidCheck">
                            Agree to terms and conditions
                        </label>
                        <div class="invalid-feedback">
                            You must agree before submitting.
                        </div>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="col-12">
                    <button class="btn btn-primary" type="submit">Submit form</button>
                </div>

            </form>

        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
        <script src="/script/newContact.js"></script>
        <script src="/script/BootStrapTheme.js"></script>

</body>

</html>