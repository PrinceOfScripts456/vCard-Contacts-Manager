<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>.json handler</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/style/MyTheme.css">
    <link rel="stylesheet" href="/style/importFile.css">
</head>

<body>

    <%- include('partials/header') %>

        <div class="row">

            <div class="glass-card">
                <div class="badge">
                    <div class="dot"></div>
                    Secure VCF Upload
                </div>
                <h1>Upload Your<br>
                    Contacts File
                </h1>
                <p class="subtitle">Drag & drop your .json file below or browse from your device. Your file will be
                    securely
                    sent
                    to the backend API.</p>
                <label for="vcfInFile" class="upload-box" id="vcfDragFile">
                    <div class="upload-icon">📇</div>
                    <div class="upload-title">Choose a .json File</div>
                    <div class="upload-desc">Supports vCard contact files only</div>
                </label>
                <input type="file" id="vcfInFile" accept=".json">
                <div class="file-info" id="fileInfo">
                    <div class="file-name" id="fileName"></div>
                    <div class="file-size" id="fileSize"></div>
                </div>
                <button type="button" class="upload-btn" id="uploadBtn" disabled>Upload File</button>
                <div class="status" id="status"></div>
                <div class="footer"> Modern frontend • Glassmorpihsm UI</div>
            </div>
        </div>

        <!-- Toast -->
        <a id="importToastBtn">importToastBtn</a>
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="importToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header">
                    <img class="rounded me-2" alt="...">
                    <strong class="me-auto">Bootstrap</strong>
                    <small>11 mins ago</small>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    Saved Succesfully! Redirecting to Contacts...
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
        <script src="/script/utils.js"></script>
        <script src="/script/importFile.js"></script>
        <script src="/script/BootStrapTheme.js"></script>

</body>

</html>